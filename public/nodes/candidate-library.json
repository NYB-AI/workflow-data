      ],
      "showWhen": [
        {
          "field": "mode",
          "in": ["vecurate"]
        }
      ]
    },
    {
      "key": "limit",
      "type": "number",
      "label": "Compound Limit",
      "placeholder": "10000",
      "defaultValue": 10000,
      "tooltip": "Maximum number of compounds to return from the selected library sources.",
      "showWhen": [
        {
          "field": "mode",
          "in": ["vecurate"]
        }
      ]
    },
    {
      "key": "compoundFile",
      "type": "compound-value-upload",
      "label": "Upload Compound List",
      "accept": ".csv,.xlsx,.xls",
      "standardType": "COMPOUND",
      "columns": {
        "smiles": { "required": true, "aliases": ["smiles", "smile", "smiles_string", "canonical_smiles"] },
        "name": { "required": false, "aliases": ["name", "compound", "mol_name", "compound_name", "compound_id"] }
      },
      "tooltip": "Upload a CSV or Excel file with compound SMILES. Name column is optional.",
      "showWhen": [{ "field": "mode", "in": ["upload"] }]
    }
  ]
