        {
          "value": "categories",
          "label": "Categories"
        },
        {
          "value": "pathway_name",
          "label": "Pathway name"
        },
        {
          "value": "core_biology",
          "label": "Core biology"
        },
        {
          "value": "included_plant_compound",
          "label": "Plant / compound"
        },
        {
          "value": "included_target",
          "label": "Target"
        },
        {
          "value": "extract_type",
          "label": "Extract type"
        }
      ],
      "defaultValue": "categories",
      "suggestedField": [
        "categories",
        "pathway_name",
        "core_biology"
      ]
    }
  ]
