{
  "type": "electrostatic-mapping",
  "label": "Electrostatic Mapping",
  "category": "analysis",
  "icon": "structure-icon",
  "color": "purple",
  "description": "Evaluates electrostatic complementarity between ligand and binding pocket using continuum electrostatics models (e.g., Poisson–Boltzmann or Generalized Born).",
  "pricing": {
    "credits": 1500,
    "executionTime": 10
  },
  "outputMockLabel": "Electrostatic Map",
  "defaultInputs": [
    {
      "id": "complex_model",
      "name": "Complex Model",
      "type": "structure",
      "required": false,
      "tooltip": "PDB file of the complex."
    },
    {
      "id": "receptor_clean",
      "name": "Receptor Clean",
      "type": "structure",
      "required": false,
      "tooltip": "Cleaned receptor PDB structure."
    },
    {
      "id": "peptide_clean",
      "name": "Peptide Clean",
      "type": "structure",
      "required": false,
      "tooltip": "Cleaned peptide PDB structure."
    }
  ],
  "defaultOutputs": [
    {
      "id": "complex_pqr",
      "name": "Complex PQR",
      "type": "structure",
      "tooltip": "PQR file with assigned charges and radii."
    },
    {
      "id": "complex_dx",
      "name": "Complex DX",
      "type": "string",
      "tooltip": "Electrostatic potential map (APBS output)."
    },
    {
      "id": "per_atom_potential_csv",
      "name": "Per-atom Potential",
      "type": "string",
      "tooltip": "CSV containing potentials per atom."
    },
    {
      "id": "electrostatic_visualization",
      "name": "Visualization",
      "type": "image",
      "tooltip": "Electrostatic visualization (PNG/DX)."
    },
    {
      "id": "electrostatics_report",
      "name": "Report",
      "type": "object",
      "tooltip": "JSON report containing hotspot analysis."
    }
  ],
  "configSchema": [
    {
      "key": "structure_file",
      "type": "file",
      "label": "Upload structure file",
      "accept": ".pdb,.pqr",
      "tooltip": "Upload structure file, in either PDB or PQR format. If you provide PQR file, you will not be able to select pH."
    },
    {
      "key": "force_field",
      "type": "select",
      "label": "Select force field parameters for protonation (Default: Amber)",
      "options": [
        { "value": "Amber", "label": "Amber" },
        { "value": "CHARMM", "label": "CHARMM" },
        { "value": "PARSE", "label": "PARSE" },
        { "value": "TYL06", "label": "TYL06" }
      ],
      "defaultValue": "Amber"
    },
    {
      "key": "ph",
      "type": "number",
      "label": "Specify pH (Default: 7)",
      "defaultValue": 7.0
    },
    {
      "key": "solver",
      "type": "select",
      "label": "While solving Poisson-Boltzmann equation, use a linear or non-linear solver? (Default: Linear)",
      "options": [
        { "value": "Linear", "label": "Linear" },
        { "value": "Non-Linear", "label": "Non-Linear" }
      ],
      "defaultValue": "Linear"
    },
    {
      "key": "perfil",
      "type": "number",
      "label": "Percent of the box to be filled by molecule (Default: perfil=70)",
      "defaultValue": 70
    },
    {
      "key": "scale",
      "type": "number",
      "label": "Resolution grids/Angstroms (Default: scale=1)",
      "defaultValue": 1.0
    },
    {
      "key": "indi",
      "type": "number",
      "label": "Internal dielectric constant (Default: indi=4.0)",
      "defaultValue": 4.0
    },
    {
      "key": "exdi",
      "type": "number",
      "label": "External dielectric constant (Default: exdi=80.0)",
      "defaultValue": 80.0
    },
    {
      "key": "salt",
      "type": "number",
      "label": "Salt concentration (Default: salt=0.15)",
      "defaultValue": 0.15
    },
    {
      "key": "bndcon",
      "type": "number",
      "label": "Boundary conditions (Default: bndcon=2)",
      "defaultValue": 2,
      "advanced": true
    },
    {
      "key": "maxc",
      "type": "number",
      "label": "Convergence criteria (Default: maxc=0.0001)",
      "defaultValue": 0.0001,
      "advanced": true
    },
    {
      "key": "prbrad",
      "type": "number",
      "label": "Probe radius (Default: prbrad=1.40)",
      "defaultValue": 1.4,
      "advanced": true
    },
    {
      "key": "linit",
      "type": "number",
      "label": "Maximum number of linear iterations (Default: linit=800)",
      "defaultValue": 800,
      "advanced": true
    },
    {
      "key": "smooth_dielectric",
      "type": "select",
      "label": "Invoking Gaussian-based smooth dielectric function (Default: disabled)",
      "options": [
        { "value": "disabled", "label": "Disabled" },
        { "value": "enabled", "label": "Enabled" }
      ],
      "defaultValue": "disabled",
      "advanced": true
    },
    {
      "key": "potential_surface",
      "type": "select",
      "label": "Invoking calculations of potential on a surface situated at a particular distance from vdW surface (Default: disabled)",
      "options": [
        { "value": "disabled", "label": "Disabled" },
        { "value": "enabled", "label": "Enabled" }
      ],
      "defaultValue": "disabled",
      "advanced": true
    },
    {
      "key": "energies_calc",
      "type": "multiselect",
      "label": "Types of energies to be calculated (Default: All Checked)",
      "options": [
        { "value": "Coulombic", "label": "Coulombic" },
        { "value": "Solvation", "label": "Solvation" },
        { "value": "Grid Energy", "label": "Grid Energy" }
      ],
      "defaultValue": ["Coulombic", "Solvation", "Grid Energy"]
    },
    {
      "key": "visualization_options",
      "type": "radio",
      "label": "Output file visualization options (Default: Potential Map)",
      "options": [
        { "value": "Potential Map", "label": "Potential Map" },
        {
          "value": "Dielectric constant map",
          "label": "Dielectric constant map"
        },
        { "value": "None", "label": "None" }
      ],
      "defaultValue": "Potential Map"
    }
  ],
  "feedsTo": ["mechanistic-hypothesis", "md-simulation"]
}
