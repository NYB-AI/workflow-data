{
  "type": "bioactivity-prediction",
  "label": "Bioactivity Prediction",
  "category": "analysis",
  "icon": "activity",
  "color": "green",
  "description": "Predict compound bioactivity (pEC50 / pIC50) across multiple biological targets using ML-based models.",
  "pricing": {
    "credits": 0,
    "executionTime": 1
  },
  "defaultInputs": [
    {
      "id": "compoundList",
      "name": "Compound List",
      "type": "array",
      "required": true,
      "description": "List of compounds to be evaluated for bioactivity"
    },
    {
      "id": "targetList",
      "name": "Target List",
      "type": "array",
      "required": true,
      "description": "List of biological targets and assay types (EC50 / IC50)"
    }
  ],
  "defaultOutputs": [
    {
      "id": "bioactivityResults",
      "name": "Bioactivity Prediction Results",
      "type": "array",
      "description": "Predicted bioactivity values (pEC50 / pIC50) per compound per target"
    },
    {
      "id": "compound_id",
      "name": "Compound ID",
      "type": "string"
    },
    {
      "id": "smiles",
      "name": "SMILES",
      "type": "string"
    },
    {
      "id": "target",
      "name": "Target",
      "type": "string"
    },
    {
      "id": "assay_type",
      "name": "Metric",
      "type": "string"
    },
    {
      "id": "assay_value",
      "name": "Predicted pIC50",
      "type": "number"
    },
    {
      "id": "status",
      "name": "Status",
      "type": "string"
    }
  ],
  "configSchema": [
    {
      "key": "modelType",
      "type": "select",
      "label": "Available Tools",
      "options": [
        {
          "value": "dtign",
          "label": "DTIGN"
        },
        {
          "value": "ligospace",
          "label": "LigoSpace"
        }
      ],
      "defaultValue": "ligospace"
    },
    {
      "key": "compoundfiles",
      "type": "file",
      "label": "Compound Files",
      "multiple": true
    }
  ]
}
